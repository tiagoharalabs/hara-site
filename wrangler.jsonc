{
  "name": "hara-site",
  "main": "src/worker.js",
  "compatibility_date": "2026-04-23",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "vars": {
    "TURNSTILE_SITE_KEY": "0x4AAAAAADEZ6ZEdazOVA7aH"
  },
  "r2_buckets": [
    {
      "binding": "DIAGNOSTICS_BUCKET",
      "bucket_name": "hara-site-diagnostics-inbox"
    }
  ]
}
